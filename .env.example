# Redis Configuration
NUM_REDIS_NODES=3
MAX_REDIS_NODES=5
REDIS_CACHE_TTL=300
CACHE_PREFIX_MAX_LEN=20
VIRTUAL_NODES_PER_RING=150

# Redis Connection
REDIS_NODE_1_HOST=redis-node-1
REDIS_NODE_1_PORT=6379
REDIS_NODE_2_HOST=redis-node-2
REDIS_NODE_2_PORT=6380
REDIS_NODE_3_HOST=redis-node-3
REDIS_NODE_3_PORT=6381
REDIS_NODE_4_HOST=redis-node-4
REDIS_NODE_4_PORT=6382
REDIS_NODE_5_HOST=redis-node-5
REDIS_NODE_5_PORT=6383
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6384

# Batch Write Configuration
BATCH_FLUSH_INTERVAL=10
BATCH_FLUSH_THRESHOLD=100
BATCH_MAX_RETRIES=3

# Trending Configuration
TRENDING_WINDOW_HOURS=24
RECENCY_WEIGHT=0.3

# Database Configuration
POSTGRES_USER=typeahead_user
POSTGRES_PASSWORD=typeahead_pass
POSTGRES_DB=typeahead
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Application
BACKEND_PORT=8000
FRONTEND_PORT=5173
LOG_LEVEL=INFO
